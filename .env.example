DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
ALLOWED_EMAIL=your-email@gmail.com
SPARK_MARGIN_V1_DEFAULT=1
# Optional allow-list override (comma-separated user IDs)
SPARK_MARGIN_V1_USERS=
# Optional shadow mode users (comma-separated user IDs)
SPARK_MARGIN_V1_SHADOW_USERS=
PREDICTIVE_MODEL_KEY=seq_linear_v1
PREDICTIVE_MODEL_CONFIG_JSON={}
# Optional: enables placeholder neural adapter registration.
PREDICTIVE_ENABLE_NN_TEMPORAL=0
# Optional: internal admin endpoint bearer secret.
PREDICTIVE_ADMIN_SECRET=
